<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ev_upload_invoices_form" model="ir.ui.view">
        <field name="name">ev.upload.invoices.wizard.form</field>
        <field name="model">pkf.clientes.wizard</field>
        <field name="arch" type="xml">
            <form string="Subir Factura">
                <group>
                    <field name="file" filename="filename" />
                    <field name="send_to_client" />
                </group>
                <footer>
                    <button string="Procesar"
                        type="object"
                        name="action_run"
                        class="btn-primary" />
                    <button string="Cancelar" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

</odoo>