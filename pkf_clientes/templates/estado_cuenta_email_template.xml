<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="estado_cuenta_email_template" model="mail.template">
        <field name="name">Estado de cuenta de clientes PKF</field>

        <field name="model_id" ref="base.model_ir_ui_view" />

        <field name="auto_delete" eval="True" />

        <field name="subject">Estado de cuenta - {{ ctx.get('razon_social', '') }}</field>

        <field name="body_html" type="html">
            <t t-set="metadata" t-value="ctx.get('metadata', {})" />
            <div style="font-family: sans-serif; font-size:14px; color:#333; padding: 5px;">

                <table class="table"
                    style="border-bottom: solid thin #e8e8e8;border-collapse:collapse; width:100%;">
                    <tr>
                        <td>
                            <img
                                t-att-src="ctx.get('logo', 'https://pkf.com/media/30rftrgj/pkf-2-logo.svg')"
                                alt="logo" width="250" />
                        </td>
                        <td>
                            <p style="text-align: end;font-size: 16px;">Estado de Cuenta Marzo 2026</p>
                        </td>
                    </tr>
                </table>
                <br />
                <h1 style="color: #0f3780; font-size: 30px;">¡Buen día!</h1>
                <br />
                <p> Nos permitimos compartirle por este medio su <strong>Estado
                        de Cuenta</strong> al día de <strong>
                        <t t-out="ctx.get('fecha','')" />
                    </strong>. En caso de
                    requerir una aclaración, le agradecemos contactarnos al correo <a
                        href="mailto:facturacion.mty@pkf.com.mx"
                        style="color:#000; font-weight:bold;text-decoration: none;">
                    facturacion.mty@pkf.com.mx
                    </a> o al
                    teléfono <a
                        href="tel:8183638211"
                        style="font-weight:bold;color:#333;text-decoration:none;">(81) 8363 8211 y
                        12</a>
                </p>

                <br />
                <br />

                <p>
                    <span
                        style="background-color: #0f3780;color: #fff; padding:5px;font-weight: bold;">Saldo
                        total:
                    </span>
                    <![CDATA[&nbsp;]]>
                    <t t-out="metadata.get('saldo_total')" />
                </p>

                <p>
                    <span
                        style="background-color: #0f3780;color: #fff; padding:5px;font-weight: bold;">Saldo
                        pendiente:
                    </span>
                    <![CDATA[&nbsp;]]>
                    <t t-out="metadata.get('pendiente_total')" />
                </p>

                <br />
                <br />
                <t t-foreach="ctx.get('facturas', [])" t-as="fact">
                    <t t-set="facturas" t-value="fact.get('facturas',[])" />
                    <t t-if="len(facturas) > 0">

                        <t t-set="color" t-value="fact.get('color','#333')" />

                        <h1 t-att-style="'color:' + color">
                            <t t-out="fact.get('title')" />
                        </h1>

                        <table style="border-collapse:collapse; width:100%;">
                            <thead t-att-style="'color:#fff;background-color:' + color">
                                <tr>
                                    <th
                                        t-att-style="'padding:8px;font-weight: bold;color: #fff;background-color: ' + color+';'">
                                        Fecha</th>
                                    <th
                                        t-att-style="'padding:8px;font-weight: bold;color: #fff;background-color: ' + color+';'">
                                        Folio</th>
                                    <th
                                        t-att-style="'padding:8px;font-weight: bold;color: #fff;background-color: ' + color+';'">
                                        Concepto</th>
                                    <th
                                        t-att-style="'padding:8px;font-weight: bold;color: #fff;background-color: ' + color+';'">
                                        Total</th>
                                    <th
                                        t-att-style="'padding:8px;font-weight: bold;color: #fff;background-color: ' + color+';'">
                                        Pendiente</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="facturas" t-as="inv">
                                    <t t-set="status" t-value="inv.get('estatus','')" />
                                    <tr>
                                        <td
                                            style="border:1px solid #e8e8e8; padding:8px; font-size: 12px;">
                                            <t t-out="inv.get('fecha')" />
                                        </td>
                                        <td
                                            style="border:1px solid #ddd; padding:8px; font-size: 12px;">
                                            <t t-out="inv.get('serie_folio')" />
                                        </td>
                                        <td
                                            style="border:1px solid #e8e8e8; padding:8px; font-size: 12px;">
                                            <t t-out="inv.get('observaciones')" />
                                        </td>
                                        <td
                                            style="border:1px solid #e8e8e8; padding:8px; font-size: 12px;">
                                            <t t-out="inv.get('total')" />
                                        </td>
                                        <td
                                            style="border:1px solid #e8e8e8; padding:8px; font-size: 12px;">
                                            <t t-out="inv.get('pendiente')" />
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                </t>
                <br />
                <br />
                <img t-att-src="ctx.get('banner', '')" alt="banner" width="450" height="120" />
                <br />
                <a
                    href="https://maps.app.goo.gl/JrjAnRPg6h5cqXrM9"
                    style="font-size:10px;font-style:italic;color:#9E9E9E;"
                >
                    Edificio Horizontes, Obispado H02 - Padre Mier No. 1545, Piso 6
                </a>
            </div>
        </field>

    </record>

</odoo>