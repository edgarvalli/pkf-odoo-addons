<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="estado_cuenta_email_template" model="mail.template">
        <field name="name">Estado de cuenta de clientes PKF</field>

        <field name="model_id" ref="base.model_ir_ui_view" />

        <field name="auto_delete" eval="True" />

        <field name="subject">Estado de cuenta - {{ ctx.get('razon_social', '') }}</field>

        <field name="body_html" type="html">
            <t t-set="metadata" t-value="ctx.get('metadata', {})" />
            <style>
                .table {
                border-collapse: collapse;
                }
            </style>
            <div style="font-family: Arial, sans-serif; font-size:12px; color:#333;">

                <img t-att-src="ctx.get('logo')" style="width:150px;" />

                <p> Hola <t t-out="ctx.get('razon_social','')" />, </p>

                <p>
                    Te enviamos tu estado de cuenta actualizado.
                </p>

                <p>
                    Si tienes alguna duda, por favor contáctanos.
                </p>

                <p>
                    <strong> Saldo total:</strong>
                    <t t-out="metadata.get('saldo_total')" />
                </p>

                <p>
                    <strong> Saldo pendiente:</strong>
                    <t t-out="metadata.get('pendiente_total')" />
                </p>

                <table style="border-collapse:collapse; width:100%;">
                    <thead>
                        <tr>
                            <th
                                style="border:1px solid #ddd; padding:8px;font-weight: bold;color: #fff;background-color: #0a2555;font-size:14px;">
                                Fecha</th>
                            <th
                                style="border:1px solid #ddd; padding:8px;font-weight: bold;color: #fff;background-color: #0a2555;font-size:14px;">
                                Folio</th>
                            <th
                                style="border:1px solid #ddd; padding:8px;font-weight: bold;color: #fff;background-color: #0a2555;font-size:14px;">
                                UUID</th>
                            <th
                                style="border:1px solid #ddd; padding:8px;font-weight: bold;color: #fff;background-color: #0a2555;font-size:14px;">
                                Concepto</th>
                            <th
                                style="border:1px solid #ddd; padding:8px;font-weight: bold;color: #fff;background-color: #0a2555;font-size:14px;">
                                Total</th>
                            <th
                                style="border:1px solid #ddd; padding:8px;font-weight: bold;color: #fff;background-color: #0a2555;font-size:14px;">
                                Pendiente</th>
                            <th
                                style="border:1px solid #ddd; padding:8px;font-weight: bold;color: #fff;background-color: #0a2555;font-size:14px;">
                                Estatus</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="ctx.get('facturas', [])" t-as="inv">
                            <t t-set="status" t-value="inv.get('estatus','')" />
                            <tr>
                                <td style="border:1px solid #ddd; padding:8px; font-size: 12px;">
                                    <t t-out="inv.get('fecha')" />
                                </td>
                                <td style="border:1px solid #ddd; padding:8px; font-size: 12px;">
                                    <t t-out="inv.get('serie_folio')" />
                                </td>
                                <td style="border:1px solid #ddd; padding:8px; font-size: 12px;">
                                    <t t-out="inv.get('uuid')" />
                                </td>
                                <td style="border:1px solid #ddd; padding:8px; font-size: 12px;">
                                    <t t-out="inv.get('observaciones')" />
                                </td>
                                <td style="border:1px solid #ddd; padding:8px; font-size: 12px;">
                                    <t t-out="inv.get('total')" />
                                </td>
                                <td style="border:1px solid #ddd; padding:8px; font-size: 12px;">
                                    <t t-out="inv.get('pendiente')" />
                                </td>
                                <td
                                    t-att-style="'border:1px solid #ddd; padding:8px;font-size:12px;color:%s' % (
                                    '#57b33e' if status == 'Vigente' else
                                    '#ffc72e' if status =='Vencido a 60 dias' else
                                    '#f26e1e' if status == 'Vencido a 90 dias' else
                                    '#e42725' if status == 'Vencido' else 
                                    '#0a2555'
                                )">
                                    <t t-out="status" />
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <p> Saludos,<br /> PKF Monterrey</p>
            </div>
        </field>

    </record>

</odoo>