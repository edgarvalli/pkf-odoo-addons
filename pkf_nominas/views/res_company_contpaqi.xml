<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ev_res_company_contpaqi_view_form" model="ir.ui.view">
        <field name="name">ev_res_company_contpaqi.view.form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='work_information']//group[.//field[@name='company_id']]"
                position="inside">
                <field name="ev_employee_code" />
            </xpath>
        </field>
    </record>

</odoo>